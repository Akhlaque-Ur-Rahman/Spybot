generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  EDITOR
  REVIEWER
}

enum SubmissionStatus {
  NEW
  IN_REVIEW
  RESOLVED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          UserRole     @default(REVIEWER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Page {
  id            String         @id @default(cuid())
  key           String         @unique
  title         String
  slug          String         @unique
  status        String         @default("draft")
  seoTitle      String?
  seoDescription String?
  sections      Section[]
  versions      PageVersion[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Section {
  id         String   @id @default(cuid())
  pageId     String
  key        String
  label      String
  position   Int
  isEnabled  Boolean  @default(true)
  page       Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blocks     Block[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([pageId, key])
}

model Block {
  id         String   @id @default(cuid())
  sectionId  String
  key        String
  type       String
  position   Int
  draftJson  Json
  liveJson   Json
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sectionId, key])
}

model PageVersion {
  id          String   @id @default(cuid())
  pageId       String
  version      Int
  snapshotJson Json
  note         String?
  publishedAt  DateTime @default(now())
  page         Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, version])
}

model MediaAsset {
  id          String   @id @default(cuid())
  url         String
  alt         String?
  tags        String[]
  mimeType    String?
  referenceKey String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NavigationMenu {
  id        String     @id @default(cuid())
  key       String     @unique
  items     NavItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model NavItem {
  id          String         @id @default(cuid())
  menuId      String
  label       String
  href        String
  description String?
  position    Int
  menu        NavigationMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormSubmission {
  id        String           @id @default(cuid())
  formType  String
  payload   Json
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId      String?
  action       String
  entityType   String
  entityId     String
  beforeJson   Json?
  afterJson    Json?
  metadataJson Json?
  createdAt    DateTime @default(now())
  actor        User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}
