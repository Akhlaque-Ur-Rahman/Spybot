# Default dev URL matches docker-compose.yml (Postgres on host port 5433).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/spybot"

# Base URL of this app (NextAuth). Must match the URL the browser uses.
# Local: use the exact port printed when you run `pnpm dev` (not always 3000 if 3000 is busy).
NEXTAUTH_URL="http://localhost:3000"
# Cloudflare quick tunnel (trycloudflare): after `cloudflared tunnel --url http://localhost:<port>`,
# copy the https://….trycloudflare.com URL into NEXTAUTH_URL, restart `pnpm dev`, then open that URL in the browser.
#
# Avoid 502 from tunnel ↔ dev port mismatch: pin dev to one port (e.g. 3000) and use the same in cloudflared:
#   PORT=3000
#   DEV_STRICT_PORT=1

# Canonical origin for VideoObject / absolute URLs (defaults to https://spybot.ai if unset).
# NEXT_PUBLIC_SITE_URL="https://your-production-domain.com"

NEXTAUTH_SECRET="replace-with-random-secret"
ADMIN_EMAIL="owner@spybot.ai"
ADMIN_PASSWORD="ChangeMe123!"
# Optional locally: leave unset or empty to skip the admin CSRF header check. For shared/staging/production,
# set a long random secret (same pattern as NEXTAUTH_SECRET), e.g. `openssl rand -hex 32` — not a third-party URL.
CMS_CSRF_TOKEN=
