{
  "name": "spybot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "tokens:check": "node scripts/check-token-usage.mjs",
    "lint:strict": "pnpm lint && pnpm tokens:check",
    "test": "node scripts/test.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate:fintech-hero-media": "tsx scripts/migrate-fintech-hero-media.ts",
    "db:migrate:fintech-hero-media:dry": "tsx scripts/migrate-fintech-hero-media.ts --dry-run",
    "db:migrate:fintech-hero-media:dry:one": "tsx scripts/migrate-fintech-hero-media.ts --dry-run --block-key=fintechHero"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.3",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
